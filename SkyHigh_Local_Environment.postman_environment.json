{
  "id": "skyhigh-local-env",
  "name": "SkyHigh Local Development",
  "values": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api/v1",
      "description": "Base URL for the SkyHigh API",
      "enabled": true
    },
    {
      "key": "flight_id",
      "value": "1",
      "description": "Demo flight ID (seeded on startup)",
      "enabled": true
    },
    {
      "key": "passenger_id",
      "value": "1",
      "description": "Demo passenger ID",
      "enabled": true
    },
    {
      "key": "seat_id",
      "value": "3",
      "description": "Seat ID to use in examples",
      "enabled": true
    },
    {
      "key": "checkin_id",
      "value": "1",
      "description": "Check-in ID (set after starting check-in)",
      "enabled": true
    },
    {
      "key": "jwt_token",
      "value": "your-jwt-token-here",
      "description": "JWT token for authenticated requests. Replace with actual token.",
      "enabled": true
    }
  ],
  "_postman_variable_scope": "environment"
}